# Shopify（dev 由 CLI 自动注入；生产在 Railway Variables 里填）
# SHOPIFY_API_KEY=
# SHOPIFY_API_SECRET=
# SHOPIFY_APP_URL=
# SCOPES=read_products,read_inventory,read_locations

# ── 数据库（Postgres）──────────────────────────────────────────────
# 生产：Railway 自动注入 ${{Postgres.DATABASE_URL}}
# 本地：填 Railway 上那个 dev Postgres 的连接串
DATABASE_URL=

# ── 邮件（Lark SMTP）──────────────────────────────────────────────
# 未配置 RESEND_API_KEY 时走 SMTP。Lark：smtp.larksuite.com:465 SSL。
SMTP_HOST=smtp.larksuite.com
SMTP_PORT=465
SMTP_SECURE=true
SMTP_USER=chill@cinegearpro.co.uk
SMTP_PASS=

# 可选：切 Resend（HTTP，Workers 用）时填；填了就优先 Resend
# RESEND_API_KEY=
